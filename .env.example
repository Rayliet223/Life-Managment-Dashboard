# Path to the SQLite database file (created on first run / migration).
DATABASE_PATH=./dev.db
# HOST/PORT/ORIGIN are read by the adapter-node server in production (systemd env file).
#HOST=127.0.0.1
#PORT=3000
#ORIGIN=http://192.168.0.226
